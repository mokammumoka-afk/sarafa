# Supabase (safe for the browser — anon key is public by design)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Company info shown in the app — these are FALLBACKS only. The live values
# admins actually edit from /admin/settings live in the `settings` table
# (company_info key) and take priority via useSettings(); these env vars are
# just what's used before that table has been configured, or at build time.
VITE_COMPANY_NAME=Sarafa Libya
VITE_COMPANY_USDT_WALLET=TRXxxxxxxxxxxxxxxxxx
VITE_APP_URL=https://your-app.pages.dev

# ─────────────────────────────────────────────────────────────
# Server-side ONLY — set these as Supabase Edge Function secrets
# (`supabase secrets set KEY=value`), never in this .env / never
# prefixed with VITE_, or they will be bundled into the browser JS.
# ─────────────────────────────────────────────────────────────
# SUPABASE_SERVICE_ROLE_KEY=...
# SUPABASE_ANON_KEY=...        (edge functions also need this to verify user JWTs)
# GPAY_API_KEY=...
# GPAY_SECRET_KEY=...
# GPAY_PASSWORD=...
# GPAY_BASE_URL=https://gpay.ly/banking/api/onlinewallet/v1
